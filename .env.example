# ============================================================
# CASINO BACKEND — Environment Variables
# Copy this file to .env and fill in all values
# ============================================================

# Server
PORT=3001
JWT_SECRET=change_this_to_a_long_random_secret_string_here

# Admin credentials (auto-seeded on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_admin_password

# ── ETH / ERC-20 Master Wallet ───────────────────────────────
ETH_MASTER_PRIVATE_KEY=0xyour_eth_private_key_here

# Etherscan API key (free at etherscan.io/myapikey)
ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETHERSCAN_BASE_URL=https://api.etherscan.io/api

# ── Solana Master Wallet ─────────────────────────────────────
SOL_MASTER_PRIVATE_KEY=your_solana_private_key_base58

# Solana RPC endpoint
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# ── Token Contract Addresses (do not change) ─────────────────
USDT_ETH_CONTRACT=0xdAC17F958D2ee523a2206206994597C13D831ec7
USDC_ETH_CONTRACT=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
USDT_SOL_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
USDC_SOL_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── Encryption ───────────────────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_KEY=32_chars_long_secret_key_here!!!

# ── Conversion rate ──────────────────────────────────────────
COINS_PER_DOLLAR=2000

# ── CoinGecko (no key needed for free tier) ─────────────────
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
